# CypherPulse Configuration
# Copy this file to .env and fill in your values

# Twitter API key from twitterapi.io
# Get your API key at https://twitterapi.io/?ref=quenosai
TWITTER_API_KEY=your_api_key_here

# Your Twitter username (without @)
TWITTER_USERNAME=your_username

# Web dashboard port (default: 8080)
PORT=8080

# Optional: Custom database path
# DB_PATH=/path/to/custom/location/analytics.db
